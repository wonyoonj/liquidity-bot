# Copy to .env for local testing. In GitHub Actions, use repo Secrets instead
# (see README.md "Full environment variable reference").

# --- Required ---
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_channel_chat_id_here

# --- Optional: failure alerts to yourself ---
ADMIN_CHAT_ID=

# --- Optional: data source override ---
SITE_API_BASE=https://americayoudongsung.netlify.app

# --- CONFIRM THIS: your actual live English page ---
SITE_URL=https://americayoudongsung.netlify.app/en

# --- Optional: Monday economic calendar (free, instant signup) ---
# https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# --- Optional: Threads mirror posting ---
# See README.md "One-time Threads setup" for how to get these.
THREADS_USER_ID=
THREADS_ACCESS_TOKEN=

# --- Optional: Threads token self-refresh (only needed if using Threads) ---
GH_PAT=
GH_REPO=yourname/your-repo

# --- Optional: LLM-generated commentary ("gemini" or "openai") ---
LLM_PROVIDER=gemini
GEMINI_API_KEY=
OPENAI_API_KEY=
 
